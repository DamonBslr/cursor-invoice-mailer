# ---------------------------------------------------------------------------
# Cursor Invoice Mailer — environment configuration
# Copy this file to .env for local use, and set the same values as
# Vercel project environment variables for the deployed cron job.
# ---------------------------------------------------------------------------

# --- Cursor login (used ONLY by the local bootstrap-login script) ----------
# Never deployed to Vercel. Used once to auto-fill the login form; you will
# still get a chance to complete any verification step by hand.
CURSOR_LOGIN_EMAIL=you@example.com
CURSOR_LOGIN_PASSWORD=

# --- Invoice source (configurable) ------------------------------------------
INVOICE_SOURCE_URL=https://cursor.com/dashboard/billing
# CSS selectors used to scrape the invoice table (confirmed against Cursor's
# real billing page markup — a <table> with one row per invoice). Scoped to
# the table with an "Invoice" column header, since the page also renders an
# unrelated per-model usage cost breakdown table (no such column) above it.
# Run `npm run run-once -- --dry-run` and adjust if your account's page differs.
INVOICE_ROW_SELECTOR=table:has(th:has-text("Invoice")) tbody tr
INVOICE_DATE_SELECTOR=td:nth-child(1)
# Row-scoped "View" link — this is a Stripe Hosted Invoice Page, not the PDF itself.
INVOICE_DOWNLOAD_SELECTOR=td:last-child a[href]
# Selectors for the real PDF download controls, evaluated on that hosted
# invoice page. Both are <button>s with no href (not <a> tags) — Stripe
# generates the PDFs client-side. The mailer downloads both for each row.
INVOICE_PDF_LINK_SELECTOR=button:has-text("Download invoice"), a[href*="/pdf"], a[href$=".pdf"]
RECEIPT_PDF_LINK_SELECTOR=button:has-text("Download receipt")
# How many of the most recent invoices to fetch each run
INVOICE_COUNT=1

# --- Recipient ---------------------------------------------------------------
RECIPIENT_EMAIL=finance@example.com

# --- Mail provider: smtp | resend | sendgrid ---------------------------------
MAIL_PROVIDER=smtp
MAIL_FROM="Cursor Invoice Mailer <invoices@example.com>"

# SMTP settings (used when MAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Resend settings (used when MAIL_PROVIDER=resend)
RESEND_API_KEY=

# SendGrid settings (used when MAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# --- Session storage & encryption --------------------------------------------
# 32-byte (64 hex chars) key, e.g. generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=
# Vercel Blob read/write token (from `vercel blob` / project settings)
BLOB_READ_WRITE_TOKEN=
# Optional: override the blob pathnames used to store the encrypted session
# and the sent-invoice ledger. Defaults shown below are fine for most setups.
# SESSION_BLOB_KEY=cursor-invoice-mailer/session.enc
# LEDGER_BLOB_KEY=cursor-invoice-mailer/ledger.json

# --- Cron security -------------------------------------------------------------
# Vercel automatically sends this as a Bearer token to your cron route.
# Set the same value here and as a Vercel env var.
CRON_SECRET=

# --- Behavior ------------------------------------------------------------------
DRY_RUN=false
MAX_RETRIES=3
RETRY_DELAY_MS=1000
LOG_LEVEL=info
