{
  "name": "cursor-invoice-mailer",
  "version": "1.0.0",
  "private": true,
  "description": "Automated monthly retrieval and emailing of Cursor billing invoices via Playwright, deployed as a Vercel Cron job.",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p public && cp static/index.html public/index.html",
    "bootstrap-login": "tsx scripts/bootstrap-login.ts",
    "run-once": "tsx scripts/run-once.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "@sparticuz/chromium": "^149.0.0",
    "@vercel/blob": "^2.5.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright-core": "^1.49.1",
    "resend": "^4.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vercel/node": "^3.2.24",
    "eslint": "^8.57.1",
    "playwright": "^1.49.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
